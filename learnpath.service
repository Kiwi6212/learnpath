[Unit]
Description=LearnPath - Personal IT Learning Platform
After=network.target

[Service]
Type=notify
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/LearnPath
EnvironmentFile=/home/ubuntu/LearnPath/.env
ExecStart=/home/ubuntu/LearnPath/venv/bin/gunicorn --bind 0.0.0.0:8083 --workers 2 --timeout 120 run:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
